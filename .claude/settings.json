{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/block-autogen-edits.cjs" },
          { "type": "command", "command": "node .claude/hooks/protect-project-config.cjs" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/generate-meta.cjs" }
        ]
      }
    ]
  }
}
